<!DOCTYPE html>
<html lang="en" data-theme="lofi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{ title }}</title>

    <meta
      name="twitter:image"
      content=""
    >
    <link rel="stylesheet" href="/assets/styles.css">
  </head>
  <body>
    <header class="site-header border-b border-base-300">
      <div class="content-container py-3 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 no-underline">
          <div class="logo-placeholder w-8 h-8 bg-base-300 rounded"></div>
          <span class="font-bold text-base">fine</span>
        </a>
        <nav class="flex items-center gap-4">
          <a href="/#install" class="text-sm no-underline hover:underline">Install</a>
          <a href="/#usage" class="text-sm no-underline hover:underline">Usage</a>
          <a href="/#format" class="text-sm no-underline hover:underline">Format</a>
        </nav>
      </div>
    </header>
    <div class="prose content-container py-8">
      {{ content }}
    </div>
  </body>
</html>

